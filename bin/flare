#!/usr/bin/env bash
# Flare - Ultimate Linux Launcher
# Main entry point script

set -e

# Determine installation directory
if [ -d "/app/lib/flare" ]; then
    APP_DIR="/app/lib/flare"
    IS_FLATPAK=true
elif [ -d "/usr/local/lib/flare" ]; then
    APP_DIR="/usr/local/lib/flare"
    IS_FLATPAK=false
elif [ -d "/usr/lib/flare" ]; then
    APP_DIR="/usr/lib/flare"
    IS_FLATPAK=false
else
    # Fallback to script directory (for development)
    SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
    APP_DIR="$(dirname "$SCRIPT_DIR")"
    IS_FLATPAK=false
fi

# Flatpak: disable SUID sandbox and use wayland, set PATH to bundled node_modules
if [ "$IS_FLATPAK" = "true" ]; then
    export ELECTRON_OZONE_PLATFORM_HINT=wayland
    export PATH="$APP_DIR/node_modules/.bin:$PATH"
    export npm_config_prefix="$APP_DIR"
fi

# Ensure dependencies are installed (skip for Flatpak, where they're bundled)
if [ ! -d "$APP_DIR/node_modules" ] && [ "$IS_FLATPAK" != "true" ]; then
    echo "📦 Installing Node.js dependencies..."
    cd "$APP_DIR"
    npm install --save-dev electron
fi

# Launch the app
cd "$APP_DIR"

# Use direct path to electron in Flatpak to avoid npm sandbox issues
if [ "$IS_FLATPAK" = "true" ] && [ -f "$APP_DIR/node_modules/electron/dist/electron" ]; then
    exec "$APP_DIR/node_modules/electron/dist/electron" --no-sandbox main.js "$@"
else
    exec npx electron main.js "$@"
fi

