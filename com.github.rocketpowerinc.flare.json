{
  "app-id": "com.github.rocketpowerinc.flare",
  "runtime": "org.gnome.Platform",
  "runtime-version": "46",
  "sdk": "org.gnome.Sdk",

  "command": "flare",
  "finish-args": [
    "--share=network",
    "--share=ipc",
    "--socket=wayland",
    "--socket=x11",
    "--socket=pulseaudio",
    "--device=dri",
    "--filesystem=home",
    "--filesystem=/run/user",
    "--talk-to-name=org.freedesktop.Flatpak",
    "--allow=devel"
  ],
  "modules": [
    {
      "name": "nodejs",
      "buildsystem": "simple",
      "build-commands": [
        "cp -r node-v18.20.1-linux-x64/* /usr/local/"
      ],
      "sources": [
        {
          "type": "archive",
          "url": "https://nodejs.org/dist/v18.20.1/node-v18.20.1-linux-x64.tar.xz",
          "sha256": "1d08285abd9fad971af5c73d13e8f2a6ae9f2906ee036095dad7d5c286642a4e"
        }
      ]
    },
    {
      "name": "flare",
      "buildsystem": "simple",
      "build-commands": [
        "npm ci --production",
        "mkdir -p /app/bin /app/lib/flare",
        "cp -r . /app/lib/flare/",
        "cat > /app/bin/flare << 'EOF'\n#!/bin/bash\nexec /app/lib/flare/bin/flare \"$@\"\nEOF",
        "chmod +x /app/bin/flare"
      ],
      "sources": [
        {
          "type": "git",
          "url": "https://github.com/rocketpowerinc/flare.git",
          "branch": "main"
        }
      ]
    },
    {
      "name": "desktop-file",
      "buildsystem": "simple",
      "build-commands": [
        "mkdir -p /app/share/applications",
        "cp config/flare.desktop /app/share/applications/com.github.rocketpowerinc.flare.desktop"
      ],
      "sources": [
        {
          "type": "git",
          "url": "https://github.com/rocketpowerinc/flare.git",
          "branch": "main"
        }
      ]
    }
  ]
}
